{
  "name": "osgqopengl",
  "version-semver": "4.1.2-2026.4.14",
  "description": "OpenSceneGraph Qt library for using Qt with OpenSceneGraph.",
  "homepage": "https://github.com/emminizer/osgQOpenGL",
  "license": null,
  "supports": "!(arm | x86 | wasm32 | xbox)",
  "dependencies": [
    {
      "name": "osg",
      "version>=": "3.5.4"
    },
    {
      "name": "vcpkg-cmake",
      "host": true
    },
    {
      "name": "vcpkg-cmake-config",
      "host": true
    }
  ],
  "default-features": [
    "qt6"
  ],
  "features": {
    "qt5": {
      "description": "Use Qt5",
      "dependencies": [
        "qt5-base"
      ]
    },
    "qt6": {
      "description": "Use Qt6",
      "dependencies": [
        "qtbase"
      ]
    }
  }
}
